# data_broker/.env.example
# Copie para data_broker/.env (gitignored) e preencha. NUNCA commite o .env.

# --- Broker (sempre necessario) ---
BROKER_PORT=3000

# Origens permitidas no CORS do Socket.IO (separadas por virgula).
# Vazio = usa os defaults de localhost em config.js.
# BROKER_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Persistencia (Stage 1 / NEU-36) ---
# URL do Redis. No docker-compose o host e o servico "redis".
REDIS_URL=redis://redis:6379

# --- Dispatch para a Cloud (Stage 3 / NEU-37) — AINDA NAO USADO nesta fase ---
# Preencher quando a Edge Function `ingest-race` existir. Ver docs/cloud-sync-contract.md.
# SUPABASE_URL=
# API_URL=
# EDGE_INGEST_TOKEN=
